rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Default deny catch-all: reject everything unless explicitly allowed below
    match /{document=**} {
      allow read, write: if false;
    }

    // Admin check: only raja.sundirect@gmail.com has global access
    function isAdmin() {
      return request.auth != null && request.auth.token.email == 'raja.sundirect@gmail.com';
    }

    // Ownership check: the requesting user's Firebase UID must match the document's userId
    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    // Users collection: each user's profile is keyed by their Firebase auth UID
    match /users/{userId} {
      allow read: if isAdmin() || isOwner(userId);
      allow create: if isAdmin() || (isOwner(userId) && request.resource.data.role == 'customer');
      allow update: if isAdmin() || (isOwner(userId) && (!('role' in request.resource.data) || request.resource.data.role == resource.data.role));
      allow delete: if isAdmin();
    }

    // Service requests: each request stores userId = request.auth.uid for ownership
    match /requests/{requestId} {
      allow list: if isAdmin() || (request.auth != null && resource.data.userId == request.auth.uid);
      allow get: if isAdmin() || (request.auth != null && resource.data.userId == request.auth.uid);
      allow create: if isAdmin() || (request.auth != null && request.resource.data.userId == request.auth.uid);
      allow update: if isAdmin() || (request.auth != null && resource.data.userId == request.auth.uid && request.resource.data.userId == resource.data.userId);
      allow delete: if isAdmin();
    }

    // Billing clearances: each clearance stores userId = request.auth.uid for ownership
    match /clearances/{subId} {
      allow list: if isAdmin() || (request.auth != null && resource.data.userId == request.auth.uid);
      allow get: if isAdmin() || (request.auth != null && resource.data.userId == request.auth.uid);
      allow create: if isAdmin() || (request.auth != null && request.resource.data.userId == request.auth.uid);
      allow update: if isAdmin() || (request.auth != null && resource.data.userId == request.auth.uid);
      allow delete: if isAdmin();
    }

    // Sent emails: keyed by user UID for audit
    match /sent_emails/{emailId} {
      allow list: if isAdmin();
      allow get: if isAdmin() || (request.auth != null && emailId == request.auth.uid);
      allow create: if isAdmin() || (request.auth != null && emailId == request.auth.uid);
      allow update: if isAdmin() || (request.auth != null && emailId == request.auth.uid);
      allow delete: if isAdmin();
    }
  }
}
